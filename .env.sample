# Build OS Environment Configuration

# Anthropic API Key (optional if using Claude Max OAuth via `claude login`)
ANTHROPIC_API_KEY=your_api_key_here

# GitHub repository URL for the output project
GITHUB_REPO_URL=https://github.com/your-org/your-repo

# Claude Code CLI path (default: claude)
CLAUDE_CODE_PATH=claude

# GitHub Personal Access Token (optional — defaults to gh auth)
GITHUB_PAT=your_github_pat_here
